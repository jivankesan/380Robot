# Single 2D object detection

# Class name of detected object
string class_name

# Detection confidence score (0.0 to 1.0)
float32 score

# Bounding box center X (normalized 0..1, left to right)
float32 cx

# Bounding box center Y (normalized 0..1, top to bottom)
float32 cy

# Bounding box width (normalized 0..1)
float32 w

# Bounding box height (normalized 0..1)
float32 h
