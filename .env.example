# ROS 2 Distribution: jazzy (Ubuntu 24.04) or humble (Ubuntu 22.04)
ROS_DISTRO=jazzy

# ROS Domain ID (0-232, different IDs create isolated networks)
ROS_DOMAIN_ID=0

# RMW Implementation
RMW_IMPLEMENTATION=rmw_fastrtps_cpp

# Serial port for Arduino (Linux)
SERIAL_PORT=/dev/ttyACM0

# Camera device (Linux)
CAMERA_DEVICE=/dev/video0

# User/Group IDs for file permissions (set to match your host user)
# Run 'id -u' and 'id -g' to get your values
HOST_UID=1000
HOST_GID=1000
